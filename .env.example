# =============================================================
# NutriTrack — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# =============================================================

# -------------------------------------------------------------
# Supabase — https://supabase.com/dashboard/project/_/settings/api
# -------------------------------------------------------------

# The public URL of your Supabase project (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# The public anonymous key (safe to expose to the browser — restricted by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# The secret service role key (server-side only — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -------------------------------------------------------------
# OpenAI — https://platform.openai.com/api-keys
# -------------------------------------------------------------

# Secret API key used for AI food recognition and nutrition insights
OPENAI_API_KEY=sk-your-openai-api-key-here
